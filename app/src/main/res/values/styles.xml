<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ثيم REMI8 الداكن -->
    <style name="AppTheme" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">#1B4F8A</item>
        <item name="colorPrimaryDark">#12151A</item>
        <item name="colorAccent">#61AFEF</item>
        <item name="android:windowBackground">#1A1D23</item>
        <item name="android:statusBarColor">#12151A</item>
        <item name="android:navigationBarColor">#12151A</item>
        <item name="android:textColor">#ABB2BF</item>
        <item name="android:textColorPrimary">#FFFFFF</item>
        <item name="android:textColorSecondary">#5C6370</item>
        <item name="android:fontFamily">monospace</item>
    </style>

    <!-- ثيم زر Script Graph -->
    <style name="GraphButton">
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">13sp</item>
        <item name="android:backgroundTint">#252830</item>
        <item name="android:layout_height">38dp</item>
        <item name="android:minWidth">48dp</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
    </style>

    <!-- ثيم محرر الكود remiscript -->
    <style name="CodeEditor">
        <item name="android:background">#282C34</item>
        <item name="android:textColor">#ABB2BF</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:padding">12dp</item>
        <item name="android:lineSpacingExtra">3dp</item>
    </style>

</resources>
