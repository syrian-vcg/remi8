<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.remi8">

    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28"/>
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"/>
    <uses-permission android:name="android.permission.VIBRATE"/>

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        android:hardwareAccelerated="true">

        <!-- Script Graph Activity (الرئيسية) -->
        <activity
            android:name=".scriptgraph.ScriptGraphActivity"
            android:exported="true"
            android:screenOrientation="landscape"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:label="Script Graph">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- محرر remiscript النصي -->
        <activity
            android:name=".editor.ScriptEditorActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:label="remiscript Editor"/>

        <!-- محرر المشاريع -->
        <activity
            android:name=".editor.EditorActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:configChanges="orientation|screenSize"
            android:label="REMI8 Editor"/>

        <!-- نشاط اللعبة -->
        <activity
            android:name=".engine.core.GameActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:configChanges="orientation|screenSize|keyboardHidden"/>

        <!-- تصدير APK -->
        <activity
            android:name=".export.ExportActivity"
            android:exported="false"
            android:label="تصدير اللعبة"/>

        <!-- خدمة المترجم -->
        <service
            android:name=".remiscript.interpreter.CompilerService"
            android:exported="false"/>

    </application>
</manifest>
